# ==============================================================
# Hatsik — Environment Variables
# ==============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env with real secrets.
# ==============================================================

# Django
SECRET_KEY=change-me-to-a-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Neon in production, local PostgreSQL in dev)
DATABASE_URL=postgres://hatsik:hatsik@localhost:5432/hatsik

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_DOMAIN=yourdomain.com

# Internal endpoints (EventBridge cron)
INTERNAL_CRON_TOKEN=change-me-to-a-random-token

# AWS (CI/CD only — not needed in App Runner env vars)
# AWS_REGION=us-east-1
# ECR_REPOSITORY=your-ecr-repo-uri
# APPRUNNER_SERVICE_ARN=arn:aws:apprunner:...
